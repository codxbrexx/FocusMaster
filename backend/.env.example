# Store real secrets in your platform secret manager.
# Local development can copy these values into an untracked `.env`.
PORT=5000
MONGO_URI=mongodb://localhost:27017/focusmaster
NODE_ENV=development
JWT_SECRET=replace_with_a_minimum_32_character_secret
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/spotify/callback
